---
// This is a server component that fetches cat images
interface Props {
  tag?: string;
}

const { tag } = Astro.props;

// Function to fetch cat images
async function fetchCatImages(tag?: string) {
  try {
    let url = 'https://cataas.com/api/cats?limit=20';
    if (tag) {
      url += `&tags=${tag}`;
    }
    const response = await fetch(url);

    if (!response.ok) {
      throw new Error(`HTTP error! Status: ${response.status}`);
    }

    return await response.json();
  } catch (error) {
    console.error('Error fetching cat images:', error);
    return [];
  }
}

// Fetch the cat images
const catImages = await fetchCatImages(tag);
---

<div>
  {/* Loading placeholder will be shown while the images are being fetched */}
  <slot name="loading" />
  
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 bg-blue-700 p-4">
    {catImages.map((cat) => (
      <div class="flex justify-center">
        <div class="w-[200px] h-auto bg-white rounded-lg shadow-md border-2 border-red-300 overflow-hidden">
          <img
            src={`https://cataas.com/cat/${cat.id}`}
            alt="Cat image"
            class="w-full h-auto object-contain"
            loading="lazy"
          />
        </div>
      </div>
    ))}
  </div>
</div> 